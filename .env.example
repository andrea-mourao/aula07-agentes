# =============================================================================
# Aula 07 · Variáveis de ambiente
# =============================================================================
# Copie este arquivo para `.env` e preencha sua chave real.
# `.env` está no .gitignore — nunca será commitado.

# --- OpenAI ---
# Sua chave de API. Comece com sk-...
# Pegue em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-COLE-SUA-CHAVE-AQUI

# Modelo padrão para o agente (function calling).
# Recomendação da aula: gpt-4.1-mini (custo/benefício ótimo).
OPENAI_MODEL=gpt-4.1-mini

# Modelo do juiz LLM para avaliação BFCL.
# Recomendação: gpt-4.1 (julgamento exige modelo grande).
OPENAI_JUDGE_MODEL=gpt-4.1

# --- Produto ativo ---
# Escolha UMA das duas opções: educiacao | designmind
PRODUCT=educiacao

# --- Servidor FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Servidor MCP local mock ---
MCP_HOST=127.0.0.1
MCP_PORT=8001

# --- Logging ---
LOG_LEVEL=INFO
